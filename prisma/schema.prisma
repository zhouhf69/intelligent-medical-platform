generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Patient {
  id            String           @id @default(cuid())
  name          String
  age           Int
  gender        String
  idCard        String?
  phone         String
  admissionDate DateTime
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  records       MedicalRecord[]
  recordings    AudioRecording[]
  images        ImageDocument[]
}

model MedicalRecord {
  id             String           @id @default(cuid())
  patientId      String
  patient        Patient          @relation(fields: [patientId], references: [id], onDelete: Cascade)
  templateId     String?
  template       MedicalTemplate? @relation(fields: [templateId], references: [id])
  doctor         String?
  doctorId       String?
  doctorUser     User?            @relation(fields: [doctorId], references: [id])
  chiefComplaint String
  presentIllness String
  pastHistory    String?
  familyHistory  String?
  physicalExam   String
  diagnosis      String
  treatment      String
  status         String           @default("draft")
  qualityScore   Int?
  qualityComment String?
  aiSuggestions  String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  recordings     AudioRecording[]
  images         ImageDocument[]
  fusionData     String?
  followUps      FollowUp[]
  collaborations Collaboration[]
}

model AudioRecording {
  id          String           @id @default(cuid())
  patientId   String
  recordId    String?
  audioUrl    String
  duration    Int
  transcription String?
  createdAt   DateTime         @default(now())
  patient     Patient          @relation(fields: [patientId], references: [id], onDelete: Cascade)
  record      MedicalRecord?    @relation(fields: [recordId], references: [id], onDelete: Cascade)
}

model ImageDocument {
  id            String           @id @default(cuid())
  patientId     String
  recordId      String?
  imageUrl      String
  type          String
  extractedData String
  createdAt     DateTime         @default(now())
  patient       Patient          @relation(fields: [patientId], references: [id], onDelete: Cascade)
  record        MedicalRecord?   @relation(fields: [recordId], references: [id], onDelete: Cascade)
}

model MedicalTemplate {
  id          String   @id @default(cuid())
  name        String
  type        String
  department  String
  fields      String
  rules       String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  records     MedicalRecord[]
}

model FollowUp {
  id          String   @id @default(cuid())
  recordId    String
  record      MedicalRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)
  followUpDate DateTime
  type        String
  status      String   @default("pending")
  notes       String?
  outcome     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Collaboration {
  id          String   @id @default(cuid())
  recordId    String
  record      MedicalRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)
  department  String
  doctor      String
  comment     String
  status      String   @default("pending")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model User {
  id          String   @id @default(cuid())
  name        String
  email       String   @unique
  password    String
  role        String
  department  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  records     MedicalRecord[]
}